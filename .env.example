# Modo de ejecución: link para vincular la cuenta o run para moderar mensajes.
WSP_MODE=run

# Número internacional opcional para vincular mediante código, por ejemplo: 56912345678
WSP_PAIR_PHONE=

# Sesión del dispositivo vinculado. Nunca incluyas esta base de datos en Git.
WSP_SESSION_DB=file:wsp-safe.db?_foreign_keys=on

# Usa preferentemente un clasificador local para que los archivos multimedia no salgan del equipo.
WSP_CLASSIFIER_URL=http://127.0.0.1:8081/v1/classify
WSP_CLASSIFIER_TOKEN=

# Valores conservadores: elimina contenido sexual, dudoso, demasiado grande o que no pueda analizarse.
WSP_SEXUAL_THRESHOLD=0.25
WSP_DELETE_UNCERTAIN=true
WSP_DELETE_ON_ERROR=true
WSP_MAX_MEDIA_BYTES=20971520
WSP_WORKERS=1

# Archivo cifrado opcional. Genera la clave una vez con: openssl rand -base64 32
# Conserva la clave fuera del repositorio; sin ella no se puede recuperar el archivo.
WSP_ARCHIVE_DELETED=false
WSP_ARCHIVE_KEY=
WSP_ARCHIVE_DIR=/data/deleted

# Registros de diagnóstico. No incluyen texto ni multimedia.
WSP_LOG_DECISIONS=false
CLASSIFIER_LOG_REQUESTS=false

# Configuración del análisis visual.
CLASSIFIER_VIDEO_SAMPLES=6

# SafeSearch se activa únicamente cuando esta clave está configurada.
GOOGLE_SAFESEARCH_API_KEY=

# Gateway rotatorio de sitios. Los proveedores con credenciales vacías se omiten.
IPQS_API_KEY=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SITE_PLAYWRIGHT_ENABLED=true
SITE_NSFW_THRESHOLD=0.25
SITE_MAX_URLS_PER_MESSAGE=3
SITE_REQUEST_TIMEOUT=30
SITE_DB_PATH=/data/site-categories.db

# Límites de recursos de Dokploy para el equipo Intel de 2012.
WSP_APP_CPUS=0.5
WSP_APP_MEMORY=256m
CLASSIFIER_CPUS=1.0
CLASSIFIER_MEMORY=3g
