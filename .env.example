# Obtain this value with: go run ./cmd/wsp-safe --list-groups
WSP_MODE=run
WSP_TARGET_GROUP_JID=120363000000000000@g.us

# Prefer a classifier running locally so media never leaves your machine.
WSP_CLASSIFIER_URL=http://127.0.0.1:8081/v1/classify
WSP_CLASSIFIER_TOKEN=

# Conservative defaults: delete sexual, uncertain, oversized and failed media.
WSP_SEXUAL_THRESHOLD=0.25
WSP_DELETE_UNCERTAIN=true
WSP_DELETE_ON_ERROR=true
WSP_MAX_MEDIA_BYTES=20971520
WSP_WORKERS=1
CLASSIFIER_VIDEO_SAMPLES=6

# Dokploy resource limits for the 2012 Intel host.
WSP_APP_CPUS=0.5
WSP_APP_MEMORY=256m
CLASSIFIER_CPUS=1.0
CLASSIFIER_MEMORY=1g

# WhatsApp linked-device session. Never commit this database.
WSP_SESSION_DB=file:wsp-safe.db?_foreign_keys=on
